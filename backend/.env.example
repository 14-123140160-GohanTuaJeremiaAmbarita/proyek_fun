# ============================================================
# KONFIGURASI SERVER
# ============================================================
PORT=5000

# ============================================================
# KONFIGURASI SQL SERVER
# Ganti dengan kredensial SQL Server perusahaan
# ============================================================
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=VokselDB
DB_USER=sa
DB_PASSWORD=your_password_here

# Jika pakai Windows Authentication (domain), set ini ke true
DB_WINDOWS_AUTH=false

# ============================================================
# KONFIGURASI CORS
# Alamat frontend React (Vite default port 5173)
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# MODE ENVIRONMENT
# ============================================================
NODE_ENV=development
